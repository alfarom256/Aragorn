# Aragorn Configuration
# Copy to .env and adjust as needed.

# kd.exe path (WinDbg Preview's kernel debugger)
# KD_EXE_PATH=C:\Program Files\WindowsApps\Microsoft.WinDbg_1.2601.12001.0_x64__8wekyb3d8bbwe\amd64\kd.exe

# Kernel debug connection string (kdnet for Hyper-V)
KD_CONNECTION=net:port=55555,key=your.debug.key.here,target=YOUR_VM_IP

# Local TCP port for kd.exe debug server (Aragorn connects here via DebugConnect)
KD_SERVER_PORT=14500

# Symbol search path
SYMBOL_PATH=srv*C:\Symbols*https://msdl.microsoft.com/download/symbols

# DbgEng DLL path — defaults to dbgeng_bin/ in this directory
# DBGENG_PATH=C:\path\to\dbgeng.dll

# HTTP server bind address and port (for --http mode)
ARAGORN_HOST=127.0.0.1
ARAGORN_PORT=14401

# VM agent — enables coordinated workflow tools
# (breakpoint_and_run, vm_exec, vm_read_file, etc.)
# Point this at any REST agent running inside the target VM.
VM_AGENT_URL=http://YOUR_VM_IP:8080
VM_AGENT_API_KEY=your_api_key_here
