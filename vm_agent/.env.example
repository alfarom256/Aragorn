# VM Agent Configuration
# Copy to .env and set your API key.

# Shared secret — must match VM_AGENT_API_KEY in Aragorn's .env
VM_AGENT_API_KEY=change-me-to-a-long-random-secret

# Network interface and port to listen on.
VM_AGENT_HOST=0.0.0.0
VM_AGENT_PORT=8080

# Maximum file size (bytes) for /file and /upload. Default: 10 MB.
MAX_FILE_SIZE=10485760
